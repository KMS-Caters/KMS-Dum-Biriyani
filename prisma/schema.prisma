generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Order {
  id Int @id @default(autoincrement())

  customerName String
  phoneNumber  String

  chickenDumQty Int @default(0)
  muttonDumQty  Int @default(0)

  chicken65Size String?
  pineappleKesariQty Int @default(0)

  deliveryDate String?
  deliveryTime String?

  deliveryAddress String?

  latitude  Float?
  longitude Float?

  paymentMode String? @default("online")

  notes String?

  totalAmount Float @default(0)

  status String @default("NEW")

  createdAt DateTime @default(now())
}
